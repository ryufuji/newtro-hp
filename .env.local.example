# --- Phase 1: 公開フロント設定 ---

# LINE 公式アカウント友だち追加URL（manage.line.biz → ホーム → 友だち追加）
# 例: https://lin.ee/XXXXXXX
NEXT_PUBLIC_LINE_FRIEND_URL=

# Tally Form ID（Premium Member 招待登録に使用）
# 例: https://tally.so/r/Y5ord5 → "Y5ord5"
NEXT_PUBLIC_TALLY_INVITE_FORM_ID=

# 旧メール登録フォーム（廃止予定）
NEXT_PUBLIC_TALLY_SIGNUP_FORM_ID=

# SNS / 公開URL
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/newtro8/
NEXT_PUBLIC_SITE_URL=https://newtique.jp

# --- Phase 1: 招待トークン ---
# /invite/[token] のサーバ側検証で使用するHMACシークレット
# 32文字以上のランダム文字列を推奨。`openssl rand -hex 32` で生成
INVITE_SECRET=
