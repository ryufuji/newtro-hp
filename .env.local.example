# --- Phase 1: 公開フロント設定 ---

# Tally Form ID（https://tally.so で作成し、フォームURLの末尾セグメントを貼る）
# 例: https://tally.so/r/wzPgN1 → "wzPgN1"
NEXT_PUBLIC_TALLY_SIGNUP_FORM_ID=
NEXT_PUBLIC_TALLY_INVITE_FORM_ID=

# SNS / 公開URL
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/newtro/
NEXT_PUBLIC_SITE_URL=https://newtro.jp

# --- Phase 1: 招待トークン ---
# /invite/[token] のサーバ側検証で使用するHMACシークレット
# 32文字以上のランダム文字列を推奨。`openssl rand -hex 32` で生成
INVITE_SECRET=
